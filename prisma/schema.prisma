// ============================================================
// T-Hex Garage — Prisma Schema
// Stack: PostgreSQL (Neon) + Prisma ORM + Next.js (App Router)
// ============================================================
// MVP: Modelos 1 (Marketplace/Comissões) + 2 (Assinaturas B2C)
// Futuro: Modelos 3 (Loja Pro) + 4 (Clube/Condomínios B2B)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Neon requer conexão direta para migrations
}

// ──────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  PAUSED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  PLATFORM_CREDIT
}

enum BoostType {
  FEED_HIGHLIGHT
  CATEGORY_TOP
  SEARCH_PRIORITY
  MEGAPHONE
}

enum CommunityMemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum CommunityMemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ProLotStatus {
  PENDING
  RECEIVED
  ANALYZING
  ACTIVE
  DONE
}

enum ProShippingMethod {
  CORREIOS
  COLETA
}

enum CashbackTransactionType {
  CREDIT_SELLER       // Vendedor ganhou 5% por venda concluída
  CREDIT_BUYER        // Comprador ganhou 2% por compra concluída
  DEBIT_PURCHASE      // Comprador usou no checkout
  REFUND_CANCELLATION // Cashback devolvido após cancelamento
  REVERSAL            // Reverte crédito anterior (transação cancelada pós-COMPLETED)
  EXPIRATION          // Saldo expirou após 120 dias
}

enum OfferStatus {
  PENDING_SELLER // Aguardando o vendedor responder
  PENDING_BUYER  // Aguardando o comprador responder (após contra-proposta)
  ACCEPTED       // Aceita; Transaction criada e linkada
  REJECTED       // Rejeitada explicitamente por uma das partes
  EXPIRED        // Não respondida em 24h
  CANCELLED      // Cancelada em cascata (outra venda do mesmo Listing concretizou)
}

enum BundleOfferStatus {
  PENDING_SELLER
  PENDING_BUYER
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

// ──────────────────────────────────────────
// CORE: USERS & AUTH
// ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?   // <- NOVO: Para login via Credenciais (hash)
  image         String?   // <- NOVO: O Auth.js exige/espera esse campo para OAuth
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  coverUrl      String?   @map("cover_url")
  bio           String?
  role          UserRole  @default(USER)
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relações MVP (Modelo 1 + 2)
  addresses              Address[]
  subscription           UserSubscription?
  listings               Listing[]               @relation("SellerListings")
  purchaseTransactions   Transaction[]            @relation("BuyerTransactions")
  saleTransactions       Transaction[]            @relation("SellerTransactions")
  viewHistories         ViewHistory[]
  reviewsWritten         Review[]                 @relation("ReviewAuthor")
  reviewsReceived        Review[]                 @relation("ReviewTarget")
  favorites              Favorite[]
  conversationMembers    ConversationParticipant[]
  messagesSent           Message[]
  accounts      Account[]
  sessions      Session[]
  emailVerificationTokens EmailVerificationToken[]
  cashbackTransactions    CashbackTransaction[]
  
  // Novas Relações (Follows e Reports)
  following Follow[] @relation("UserFollows")
  followers Follow[] @relation("UserFollowers")
  reportsWritten Report[] @relation("UserReports")
  brandFollows BrandFollow[]

  // Relações de Ofertas
  buyerOffers  Offer[]      @relation("BuyerOffers")
  sellerOffers Offer[]      @relation("SellerOffers")
  offerRounds  OfferRound[]

  // Relações de Ofertas de Bundle (Sacola)
  buyerBundleOffers  BundleOffer[] @relation("BuyerBundleOffers")
  sellerBundleOffers BundleOffer[] @relation("SellerBundleOffers")
  bundleOfferRounds  BundleOfferRound[]

  // Kloop Pro
  proLots                ProLot[]
  storeBoosts            StoreBoost[]

  // Relações Futuras (Modelo 3 + 4)
  store                  Store?
  communityMemberships   CommunityMember[]
  adminCommunities       Community[]              @relation("CommunityAdmin")

  @@map("users")
}

model Address {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  label        String   @default("Casa") // Casa, Trabalho, Outro
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @db.Char(2) // UF brasileira
  zipCode      String   @map("zip_code") @db.VarChar(9) // CEP
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("addresses")
}

// ──────────────────────────────────────────
// MVP MODELO 2: ASSINATURAS B2C
// ──────────────────────────────────────────

model SubscriptionPlan {
  id                String               @id @default(cuid())
  name              String // "Basic", "Pro", "Premium"
  slug              String               @unique
  description       String?
  priceCents        Int                  @map("price_cents") // 0 = Basic, 1500 = Pro, 4000 = Premium
  interval          SubscriptionInterval @default(MONTHLY)
  maxActiveListings Int                  @map("max_active_listings") // -1 = ilimitado
  commissionRate    Decimal              @map("commission_rate") @db.Decimal(5, 4) // 0.0800 = 8%
  megaphonesPerWeek Int                  @default(5) @map("megaphones_per_week") // Basic=5, Pro=10, Premium=25
  features          Json                 @default("{}") // { "boosts": false, "analytics": false, ... }
  isActive          Boolean              @default(true) @map("is_active")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                    String             @id @default(cuid())
  userId                String             @unique @map("user_id")
  planId                String             @map("plan_id")
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime           @map("current_period_start")
  currentPeriodEnd      DateTime           @map("current_period_end")
  gatewaySubscriptionId String?            @map("gateway_subscription_id")
  cancelledAt           DateTime?          @map("cancelled_at")
  // Controle de cota semanal de megafones
  megaphonesUsedThisWeek Int               @default(0) @map("megaphones_used_this_week")
  extraMegaphonesBalance Int               @default(0) @map("extra_megaphones_balance")
  megaphonesWeekResetAt  DateTime?         @map("megaphones_week_reset_at") // data do próximo reset
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

// ──────────────────────────────────────────
// MVP MODELO 1: MARKETPLACE / CATÁLOGO
// ──────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?  @map("parent_id")
  icon      String? // Nome do ícone (ex: "shirt", "laptop", "sofa")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id          String           @id @default(cuid())
  sellerId    String           @map("seller_id")
  storeId     String?          @map("store_id") // null = marketplace aberto
  communityId String?          @map("community_id") // null = marketplace aberto
  categoryId  String           @map("category_id")
  title       String
  slug        String           @unique
  description String
  priceCents  Int              @map("price_cents")
  condition   ListingCondition
  status      ListingStatus    @default(DRAFT)
  brandId   String?  @map("brand_id")
  brand     Brand?   @relation(fields: [brandId], references: [id])
  size        String? // Tamanho livre (P, M, G, 42, etc.)
  viewsCount  Int              @default(0) @map("views_count")
  acceptsOffers     Boolean   @default(true) @map("accepts_offers")
  smartPriceEnabled Boolean   @default(false) @map("smart_price_enabled")
  idealPriceMinCents Int?     @map("ideal_price_min_cents")
  idealPriceMaxCents Int?     @map("ideal_price_max_cents")
  // Funcionalidades de engajamento
  isTurbinado       Boolean   @default(false) @map("is_turbinado")
  isMegafonado      Boolean   @default(false) @map("is_megafonado")
  megafonadoUntil   DateTime? @map("megafonado_until") // nulo ou passado = boost inativo
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  seller      User     @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  store        Store?         @relation(fields: [storeId], references: [id])
  community    Community?     @relation(fields: [communityId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  images       ListingImage[]
  transactions Transaction[]
  viewHistories ViewHistory[]
  favorites    Favorite[]
  conversations Conversation[]
  boosts            StoreBoost[]
  offers            Offer[]
  bundleOfferItems  BundleOfferItem[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([communityId])
  @@index([storeId])
  @@index([createdAt(sort: Desc)])
  @@map("listings")
}

model ListingImage {
  id           String   @id @default(cuid())
  listingId    String   @map("listing_id")
  url          String
  publicId     String?  @map("public_id")
  displayOrder Int      @default(0) @map("display_order")
  altText      String?  @map("alt_text")
  createdAt    DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

// ──────────────────────────────────────────
// MVP: TRANSAÇÕES & REVIEWS
// ──────────────────────────────────────────

model Transaction {
  id               String            @id @default(cuid())
  listingId        String            @map("listing_id")
  buyerId          String            @map("buyer_id")
  sellerId         String            @map("seller_id")
  amountCents      Int               @map("amount_cents")
  commissionCents  Int               @map("commission_cents")
  commissionRate   Decimal           @map("commission_rate") @db.Decimal(5, 4)
  status           TransactionStatus @default(PENDING)
  gatewayPaymentId String?           @map("gateway_payment_id") // ID no gateway
  paymentMethod    PaymentMethod?    @map("payment_method")
  shippedAt        DateTime?         @map("shipped_at")
  deliveredAt      DateTime?         @map("delivered_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  shippingCents  Int               @default(0) @map("shipping_cents")
  trackingCode   String?           @map("tracking_code")
  paidAt         DateTime?         @map("paid_at")
  cancelledAt    DateTime?         @map("cancelled_at")
  completedAt    DateTime?         @map("completed_at")
  addressId      String?           @map("address_id")

  cashbackUsedCents Int @default(0) @map("cashback_used_cents")

  listing              Listing               @relation(fields: [listingId], references: [id])
  buyer                User                  @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller               User                  @relation("SellerTransactions", fields: [sellerId], references: [id])
  address              Address?              @relation(fields: [addressId], references: [id])
  review               Review?
  cashbackTransactions CashbackTransaction[]
  offer                Offer?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("transactions")
}

model CashbackTransaction {
  id            String                  @id @default(cuid())
  userId        String                  @map("user_id")
  type          CashbackTransactionType
  amountCents   Int                     @map("amount_cents")
  expiresAt     DateTime?               @map("expires_at")
  transactionId String?                 @map("transaction_id")
  parentId      String?                 @map("parent_id")
  description   String
  createdAt     DateTime                @default(now()) @map("created_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction?         @relation(fields: [transactionId], references: [id])
  parent      CashbackTransaction? @relation("CashbackParent", fields: [parentId], references: [id])
  children    CashbackTransaction[] @relation("CashbackParent")

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@map("cashback_transactions")
}

model Review {
  id            String   @id @default(cuid())
  transactionId String   @unique @map("transaction_id")
  reviewerId    String   @map("reviewer_id")
  reviewedId    String   @map("reviewed_id") // O outro lado da transação
  rating        Int // 1-5
  comment       String?
  tags          String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  reviewer    User        @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  reviewed    User        @relation("ReviewTarget", fields: [reviewedId], references: [id])

  @@index([reviewedId])
  @@map("reviews")
}

// ──────────────────────────────────────────
// MVP: FAVORITOS
// ──────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}

// ──────────────────────────────────────────
// MVP: MENSAGENS / CHAT
// ──────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  listingId String?  @map("listing_id") // Conversa pode ser sobre um anúncio específico
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing      Listing?                  @relation(fields: [listingId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ──────────────────────────────────────────
// FUTURO — MODELO 3: LOJA PRÓPRIA (PRO)
// ──────────────────────────────────────────

model Store {
  id          String   @id @default(cuid())
  ownerId     String   @unique @map("owner_id")
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  bannerUrl   String?  @map("banner_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User         @relation(fields: [ownerId], references: [id])
  listings Listing[]
  boosts   StoreBoost[]

  @@map("stores")
}

model StoreBoost {
  id           String    @id @default(cuid())
  storeId      String?   @map("store_id")   // null quando o boost é de usuário individual (megafone)
  userId       String?   @map("user_id")    // quem aplicou o megafone (null para boosts de loja futura)
  listingId    String?   @map("listing_id") // null = boost na loja inteira
  boostType    BoostType @map("boost_type")
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  creditsSpent Int       @map("credits_spent")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  store   Store?   @relation(fields: [storeId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([isActive, endDate])
  @@map("store_boosts")
}

// ──────────────────────────────────────────
// FUTURO — MODELO 4: CLUBE / CONDOMÍNIOS (B2B)
// ──────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  adminUserId String   @map("admin_user_id")
  settings    Json     @default("{}") // { "allowElectronics": true, "maxPricePerItem": 50000, ... }
  isActive    Boolean  @default(true) @map("is_active")
  maxMembers  Int      @default(500) @map("max_members")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  admin    User              @relation("CommunityAdmin", fields: [adminUserId], references: [id])
  members  CommunityMember[]
  listings Listing[]
  rules    CommunityRule[]

  @@map("communities")
}

model CommunityMember {
  id          String                @id @default(cuid())
  communityId String                @map("community_id")
  userId      String                @map("user_id")
  role        CommunityMemberRole   @default(MEMBER)
  status      CommunityMemberStatus @default(PENDING)
  unitNumber  String?               @map("unit_number") // Apartamento/bloco
  joinedAt    DateTime              @default(now()) @map("joined_at")
  createdAt   DateTime              @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId])
  @@map("community_members")
}

model CommunityRule {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  ruleType    String   @map("rule_type") // "blocked_category", "max_price", "listing_approval_required"
  ruleValue   Json     @map("rule_value") // { "categoryId": "xxx" } ou { "maxCents": 50000 }
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("community_rules")
}


// ──────────────────────────────────────────
// MVP: SISTEMA DE OFERTAS
// ──────────────────────────────────────────

model Offer {
  id                          String      @id @default(cuid())
  listingId                   String      @map("listing_id")
  buyerId                     String      @map("buyer_id")
  sellerId                    String      @map("seller_id")
  status                      OfferStatus @default(PENDING_SELLER)

  // Snapshot do preço do anúncio no momento da criação da oferta
  listingPriceCentsAtCreation Int         @map("listing_price_cents_at_creation")

  // Valor atual em negociação (último lance feito)
  currentPriceCents           Int         @map("current_price_cents")

  // Quem deve agir agora (null quando status é terminal)
  currentTurnUserId           String?     @map("current_turn_user_id")

  // Quando a oferta atual expira (24h após o último lance)
  expiresAt                   DateTime    @map("expires_at")

  // Contagem de lances (1 inicial + até 3 contra-propostas = máx. 4)
  roundsCount                 Int         @default(1) @map("rounds_count")

  // Linkagem com a Transaction criada quando aceita (null até aceitar)
  transactionId               String?     @unique @map("transaction_id")

  createdAt                   DateTime    @default(now()) @map("created_at")
  updatedAt                   DateTime    @updatedAt @map("updated_at")

  listing     Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer       User         @relation("BuyerOffers", fields: [buyerId], references: [id])
  seller      User         @relation("SellerOffers", fields: [sellerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  rounds      OfferRound[]

  @@index([listingId, status])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([expiresAt, status])
  @@map("offers")
}

model OfferRound {
  id          String   @id @default(cuid())
  offerId     String   @map("offer_id")
  roundNumber Int      @map("round_number")
  proposedBy  String   @map("proposed_by")
  priceCents  Int      @map("price_cents")
  createdAt   DateTime @default(now()) @map("created_at")

  offer    Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  proposer User  @relation(fields: [proposedBy], references: [id])

  @@unique([offerId, roundNumber])
  @@index([offerId, createdAt])
  @@map("offer_rounds")
}

// ──────────────────────────────────────────
// MVP: SEGUIR MARCAS
// ──────────────────────────────────────────

model BrandFollow {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  brandId   String   @map("brand_id")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@map("brand_follows")
}

// ──────────────────────────────────────────
// KLOOP PRO: LOTES
// ──────────────────────────────────────────

model ProLot {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  code           String            @unique
  status         ProLotStatus      @default(PENDING)
  shippingMethod ProShippingMethod @map("shipping_method")
  withBag        Boolean           @default(false) @map("with_bag")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pro_lots")
}

// ──────────────────────────────────────────
// NEXTAUTH (AUTH.JS) MODELS
// ──────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ──────────────────────────────────────────
// NOVAS TABELAS: FOLLOWS & REPORTS
// ──────────────────────────────────────────

model Follow {
  id                   String   @id @default(cuid())
  followerId           String   @map("follower_id")
  followingId          String   @map("following_id")
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String   @map("reporter_id")
  targetId    String   @map("target_id") // Pode ser ID de Usuário ou Listing
  targetType  String   @map("target_type") // "USER" ou "LISTING"
  reason      String
  description String?  @db.Text
  status      String   @default("PENDING") // PENDING, INVESTIGATING, RESOLVED, DISMISSED
  createdAt   DateTime @default(now()) @map("created_at")

  reporter User @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@map("reports")
}

// ──────────────────────────────────────────
// MVP: HISTÓRICO DE VISUALIZAÇÕES
// ──────────────────────────────────────────

model ViewHistory {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  listingId  String   @map("listing_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // Garante que o mesmo usuário não crie 500 linhas para o mesmo produto
  @@unique([userId, listingId])
  // Index para a aba "Visualizados" carregar rápido
  @@index([userId, viewedAt(sort: Desc)])
  @@map("view_history")
}

// ──────────────────────────────────────────
// MVP: OFERTAS DE BUNDLE (SACOLA)
// ──────────────────────────────────────────

model BundleOffer {
  id                          String            @id @default(cuid())
  buyerId                     String            @map("buyer_id")
  sellerId                    String            @map("seller_id")
  status                      BundleOfferStatus @default(PENDING_SELLER)

  // Soma dos preços dos itens selecionados no momento da criação (teto da oferta)
  listingTotalCentsAtCreation Int               @map("listing_total_cents_at_creation")

  // Valor atual em negociação (último lance)
  currentTotalCents           Int               @map("current_total_cents")

  // Quem deve agir agora (null quando status é terminal)
  currentTurnUserId           String?           @map("current_turn_user_id")

  expiresAt                   DateTime          @map("expires_at")
  roundsCount                 Int               @default(1) @map("rounds_count")

  createdAt                   DateTime          @default(now()) @map("created_at")
  updatedAt                   DateTime          @updatedAt @map("updated_at")

  buyer  User @relation("BuyerBundleOffers", fields: [buyerId], references: [id])
  seller User @relation("SellerBundleOffers", fields: [sellerId], references: [id])

  items  BundleOfferItem[]
  rounds BundleOfferRound[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([expiresAt, status])
  @@map("bundle_offers")
}

model BundleOfferItem {
  id                  String @id @default(cuid())
  bundleOfferId       String @map("bundle_offer_id")
  listingId           String @map("listing_id")
  priceCentsAtCreation Int   @map("price_cents_at_creation")

  bundleOffer BundleOffer @relation(fields: [bundleOfferId], references: [id], onDelete: Cascade)
  listing     Listing     @relation(fields: [listingId], references: [id])

  @@map("bundle_offer_items")
}

model BundleOfferRound {
  id            String   @id @default(cuid())
  bundleOfferId String   @map("bundle_offer_id")
  roundNumber   Int      @map("round_number")
  proposedBy    String   @map("proposed_by")
  priceCents    Int      @map("price_cents")
  createdAt     DateTime @default(now()) @map("created_at")

  bundleOffer BundleOffer @relation(fields: [bundleOfferId], references: [id], onDelete: Cascade)
  proposer    User        @relation(fields: [proposedBy], references: [id])

  @@unique([bundleOfferId, roundNumber])
  @@index([bundleOfferId, createdAt])
  @@map("bundle_offer_rounds")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listings  Listing[]
  followers BrandFollow[]

  @@map("brands")
}